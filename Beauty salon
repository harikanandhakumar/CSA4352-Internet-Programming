<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Luxury Beauty Salon</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Segoe UI',sans-serif;
scroll-behavior:smooth;
}

body{
background:url('https://images.unsplash.com/photo-1522335789203-aabd1fc54bc9?w=1600') center/cover fixed;
color:white;
}

/* Header */

header{
background:rgba(0,0,0,0.6);
backdrop-filter:blur(10px);
padding:20px 50px;
position:sticky;
top:0;
z-index:100;
}

nav{
display:flex;
justify-content:space-between;
align-items:center;
}

.logo{
font-size:32px;
font-weight:bold;
color:#FFD700;
text-shadow:0 0 20px gold;
}

/* Hero */

.hero{
height:90vh;
display:flex;
justify-content:center;
align-items:center;
text-align:center;
background:rgba(0,0,0,0.45);
}

.hero-content h1{
font-size:65px;
margin-bottom:15px;
animation:glow 2s infinite alternate;
}

.hero-content p{
font-size:24px;
margin-bottom:25px;
}

.hero-content button{
padding:15px 35px;
border:none;
border-radius:30px;
background:linear-gradient(135deg,#FFD700,#FFB300);
font-size:18px;
cursor:pointer;
font-weight:bold;
}

@keyframes glow{
from{
text-shadow:0 0 10px gold;
}
to{
text-shadow:0 0 30px gold;
}
}

/* Sections */

.container{
width:90%;
margin:auto;
padding:60px 0;
}

.section-title{
text-align:center;
font-size:40px;
margin-bottom:40px;
color:#FFD700;
}

/* Services */

.services{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:25px;
}

.card{
background:rgba(255,255,255,0.15);
backdrop-filter:blur(15px);
padding:25px;
border-radius:20px;
text-align:center;
transition:.5s;
}

.card:hover{
transform:translateY(-10px);
box-shadow:0 0 25px gold;
}

.card h3{
margin:15px 0;
}

/* Experts */

.experts{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:25px;
}

.expert{
background:rgba(255,255,255,0.15);
backdrop-filter:blur(15px);
border-radius:20px;
overflow:hidden;
transition:.5s;
}

.expert:hover{
transform:scale(1.05);
}

.expert img{
width:100%;
height:280px;
object-fit:cover;
}

.info{
padding:15px;
text-align:center;
}

/* Gallery */

.gallery{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
}

.gallery img{
width:100%;
height:250px;
object-fit:cover;
border-radius:15px;
transition:.5s;
}

.gallery img:hover{
transform:scale(1.05);
}

/* Booking Form */

.booking{
background:rgba(255,255,255,0.15);
backdrop-filter:blur(15px);
padding:30px;
border-radius:20px;
}

input,select,textarea{
width:100%;
padding:12px;
margin:10px 0;
border:none;
border-radius:10px;
}

button.submit{
background:gold;
color:black;
font-weight:bold;
padding:12px;
width:100%;
border:none;
border-radius:10px;
cursor:pointer;
}

/* Reviews */

.reviews{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:20px;
}

.review{
background:rgba(255,255,255,0.15);
padding:20px;
border-radius:15px;
backdrop-filter:blur(10px);
}

/* Footer */

footer{
background:rgba(0,0,0,0.8);
text-align:center;
padding:20px;
margin-top:50px;
}

/* Top Button */

#topBtn{
position:fixed;
bottom:20px;
right:20px;
background:gold;
border:none;
width:50px;
height:50px;
border-radius:50%;
font-size:22px;
cursor:pointer;
}

</style>
</head>

<body>

<header>
<nav>
<div class="logo">💄 Luxury Beauty Salon</div>
<div>Beauty • Makeup • Spa</div>
</nav>
</header>

<section class="hero">
<div class="hero-content">
<h1>Enhance Your Natural Beauty</h1>
<p>Professional Salon & Beauty Services</p>
<button>Book Appointment</button>
</div>
</section>

<div class="container">

<h2 class="section-title">Our Services</h2>

<div class="services">

<div class="card">
<h3>💇 Hair Styling</h3>
<p>Modern haircuts, coloring and styling.</p>
</div>

<div class="card">
<h3>💄 Bridal Makeup</h3>
<p>Luxury bridal makeup packages.</p>
</div>

<div class="card">
<h3>✨ Facial Treatment</h3>
<p>Glowing skin care treatments.</p>
</div>

<div class="card">
<h3>💅 Manicure & Pedicure</h3>
<p>Premium nail care services.</p>
</div>

</div>

<h2 class="section-title">Beauty Experts</h2>

<div class="experts">

<div class="expert">
<img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=800">
<div class="info">
<h3>Emma Wilson</h3>
<p>Hair Stylist</p>
</div>
</div>

<div class="expert">
<img src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=800">
<div class="info">
<h3>Sophia Brown</h3>
<p>Makeup Artist</p>
</div>
</div>

<div class="expert">
<img src="https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=800">
<div class="info">
<h3>Olivia Taylor</h3>
<p>Skin Specialist</p>
</div>
</div>

</div>

<h2 class="section-title">Beauty Gallery</h2>

<div class="gallery">

<img src="https://images.unsplash.com/photo-1487412720507-e7ab37603c6f?w=800">
<img src="https://images.unsplash.com/photo-1524504388940-b1c1722653e1?w=800">
<img src="https://images.unsplash.com/photo-1517841905240-472988babdf9?w=800">

</div>

<h2 class="section-title">Book Appointment</h2>

<div class="booking">

<input type="text" placeholder="Full Name">

<input type="email" placeholder="Email">

<input type="tel" placeholder="Phone Number">

<select>
<option>Hair Styling</option>
<option>Bridal Makeup</option>
<option>Facial Treatment</option>
<option>Manicure & Pedicure</option>
</select>

<input type="date">

<input type="time">

<textarea rows="4" placeholder="Additional Notes"></textarea>

<button class="submit" onclick="alert('Appointment Booked Successfully!')">
Book Appointment
</button>

</div>

<h2 class="section-title">Customer Reviews</h2>

<div class="reviews">

<div class="review">
⭐⭐⭐⭐⭐
<p>Excellent service and friendly staff.</p>
</div>

<div class="review">
⭐⭐⭐⭐⭐
<p>Bridal makeup was absolutely stunning.</p>
</div>

<div class="review">
⭐⭐⭐⭐⭐
<p>Best beauty salon experience ever.</p>
</div>

</div>

</div>

<button id="topBtn" onclick="window.scrollTo({top:0,behavior:'smooth'})">
⬆
</button>

<footer>
©️ 2026 Luxury Beauty Salon | All Rights Reserved
</footer>

</body>
</html>
