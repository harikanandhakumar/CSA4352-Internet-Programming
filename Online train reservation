<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Online Train Reservation System</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    background:linear-gradient(to right,#0f2027,#203a43,#2c5364);
    min-height:100vh;
}

header{
    background:#001f3f;
    color:white;
    text-align:center;
    padding:20px;
}

header h1{
    font-size:35px;
}

.container{
    width:90%;
    max-width:700px;
    margin:30px auto;
    background:white;
    padding:30px;
    border-radius:15px;
    box-shadow:0 0 15px rgba(0,0,0,0.3);
}

h2{
    text-align:center;
    margin-bottom:20px;
    color:#001f3f;
}

.form-group{
    margin-bottom:15px;
}

label{
    display:block;
    margin-bottom:5px;
    font-weight:bold;
}

input,select{
    width:100%;
    padding:10px;
    border:1px solid #ccc;
    border-radius:5px;
}

button{
    width:100%;
    padding:12px;
    background:#0074D9;
    color:white;
    border:none;
    border-radius:5px;
    font-size:18px;
    cursor:pointer;
}

button:hover{
    background:#0056b3;
}

.ticket{
    margin-top:30px;
    padding:20px;
    border:2px dashed #0074D9;
    border-radius:10px;
    background:#f4f9ff;
}

.ticket h3{
    text-align:center;
    color:#0074D9;
    margin-bottom:10px;
}

footer{
    text-align:center;
    color:white;
    padding:15px;
}
</style>
</head>
<body>

<header>
    <h1>🚆 Online Train Reservation System</h1>
</header>

<div class="container">
    <h2>Train Ticket Booking</h2>

    <form>
        <div class="form-group">
            <label>Passenger Name</label>
            <input type="text" placeholder="Enter Name">
        </div>

        <div class="form-group">
            <label>Age</label>
            <input type="number" placeholder="Enter Age">
        </div>

        <div class="form-group">
            <label>Gender</label>
            <select>
                <option>Male</option>
                <option>Female</option>
                <option>Other</option>
            </select>
        </div>

        <div class="form-group">
            <label>From</label>
            <input type="text" placeholder="Departure Station">
        </div>

        <div class="form-group">
            <label>To</label>
            <input type="text" placeholder="Destination Station">
        </div>

        <div class="form-group">
            <label>Travel Date</label>
            <input type="date">
        </div>

        <div class="form-group">
            <label>Select Train</label>
            <select>
                <option>Express 101</option>
                <option>Super Fast 202</option>
                <option>Chennai Express 303</option>
                <option>Intercity 404</option>
            </select>
        </div>

        <div class="form-group">
            <label>Class</label>
            <select>
                <option>Sleeper</option>
                <option>AC 3 Tier</option>
                <option>AC 2 Tier</option>
                <option>First Class</option>
            </select>
        </div>

        <button type="submit">Book Ticket</button>
    </form>

    <div class="ticket">
        <h3>E-Ticket Preview</h3>
        <p><strong>Train:</strong> Chennai Express 303</p>
        <p><strong>Passenger:</strong> Your Name</p>
        <p><strong>Seat:</strong> B2 - 25</p>
        <p><strong>Status:</strong> Confirmed</p>
        <p><strong>Fare:</strong> ₹850</p>
    </div>
</div>

<footer>
    <p>©️ 2026 Online Train Reservation System</p>
</footer>

</body>
</html>
