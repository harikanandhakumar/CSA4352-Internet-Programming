<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TechStore Premium</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Segoe UI',sans-serif;
}

body{
background:linear-gradient(-45deg,#00c6ff,#0072ff,#8e2de2,#ff0080);
background-size:400% 400%;
animation:bg 12s ease infinite;
overflow-x:hidden;
}

@keyframes bg{
0%{background-position:0% 50%;}
50%{background-position:100% 50%;}
100%{background-position:0% 50%;}
}

header{
background:rgba(0,0,0,.8);
padding:15px 40px;
display:flex;
justify-content:space-between;
align-items:center;
position:sticky;
top:0;
z-index:100;
}

.logo{
font-size:35px;
font-weight:bold;
color:#fff;
text-shadow:0 0 20px cyan;
}

.search-box{
width:300px;
padding:10px;
border:none;
border-radius:30px;
}

.controls button{
padding:10px 15px;
border:none;
border-radius:20px;
cursor:pointer;
margin-left:10px;
background:#00e5ff;
font-weight:bold;
}

.offer{
background:gold;
padding:12px;
text-align:center;
font-size:22px;
font-weight:bold;
animation:blink 1s infinite;
}

@keyframes blink{
50%{opacity:.5;}
}

/* Slider */

.hero-slider{
position:relative;
height:70vh;
overflow:hidden;
}

.slide{
display:none;
position:absolute;
width:100%;
height:100%;
}

.slide img{
width:100%;
height:100%;
object-fit:cover;
filter:brightness(50%);
}

.caption{
position:absolute;
top:50%;
left:50%;
transform:translate(-50%,-50%);
color:white;
text-align:center;
}

.caption h1{
font-size:60px;
text-shadow:0 0 20px cyan;
}

.caption p{
font-size:24px;
margin:15px;
}

.caption button{
padding:15px 30px;
border:none;
border-radius:30px;
background:#00e5ff;
cursor:pointer;
}

/* Categories */

.categories{
display:flex;
justify-content:center;
gap:20px;
flex-wrap:wrap;
padding:40px;
background:white;
}

.cat{
width:170px;
height:170px;
border-radius:20px;
background:linear-gradient(135deg,#00c6ff,#0072ff);
color:white;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
font-size:45px;
transition:.4s;
cursor:pointer;
}

.cat:hover{
transform:translateY(-10px) scale(1.05);
}

.cat h3{
font-size:20px;
margin-top:10px;
}

/* Products */

.products{
padding:40px;
}

.title{
text-align:center;
font-size:35px;
color:white;
margin-bottom:25px;
}

.product-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:25px;
}

.card{
background:rgba(255,255,255,.15);
backdrop-filter:blur(10px);
border-radius:20px;
overflow:hidden;
position:relative;
transition:.4s;
}

.card:hover{
transform:translateY(-10px);
box-shadow:0 0 30px cyan;
}

.card img{
width:100%;
height:220px;
object-fit:cover;
}

.badge{
position:absolute;
top:10px;
left:10px;
background:red;
color:white;
padding:5px 10px;
border-radius:20px;
}

.wish{
position:absolute;
top:10px;
right:10px;
background:white;
border:none;
width:40px;
height:40px;
border-radius:50%;
cursor:pointer;
}

.info{
padding:15px;
color:white;
}

.price{
font-size:24px;
font-weight:bold;
color:yellow;
margin:10px 0;
}

.btn{
width:100%;
padding:12px;
border:none;
background:#00e5ff;
border-radius:30px;
cursor:pointer;
}

/* Cart */

.cart{
position:fixed;
right:-350px;
top:0;
width:350px;
height:100%;
background:white;
padding:20px;
transition:.4s;
overflow:auto;
z-index:200;
}

.cart.active{
right:0;
}

.checkout{
width:100%;
padding:12px;
background:green;
color:white;
border:none;
margin-top:10px;
}

footer{
background:black;
color:white;
text-align:center;
padding:20px;
margin-top:30px;
}

#topBtn{
position:fixed;
bottom:20px;
right:20px;
width:50px;
height:50px;
border:none;
border-radius:50%;
background:#00e5ff;
cursor:pointer;
font-size:20px;
}

.dark{
background:#111 !important;
}
</style>

</head>

<body>

<header>
<div class="logo">⚡ TechStore</div>

<input type="text" class="search-box" id="search"
placeholder="Search Products..." onkeyup="searchProducts()">

<div class="controls">
<button onclick="darkMode()">🌙</button>
<button onclick="toggleCart()">🛒 Cart (<span id="count">0</span>)</button>
</div>
</header>

<div class="offer">🔥 MEGA SALE - UP TO 70% OFF 🔥</div>

<section class="hero-slider">

<div class="slide">
<img src="https://images.unsplash.com/photo-1518770660439-4636190af475?w=1600">
<div class="caption">
<h1>Future Technology</h1>
<p>Latest Electronics Collection</p>
<button>Shop Now</button>
</div>
</div>

<div class="slide">
<img src="https://images.unsplash.com/photo-1496181133206-80ce9b88a853?w=1600">
<div class="caption">
<h1>Gaming Laptops</h1>
<p>Powerful Performance</p>
<button>Explore</button>
</div>
</div>

<div class="slide">
<img src="https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?w=1600">
<div class="caption">
<h1>Premium Smartphones</h1>
<p>Best Deals Available</p>
<button>Buy Now</button>
</div>
</div>

</section>

<section class="categories">
<div class="cat">📱<h3>Mobiles</h3></div>
<div class="cat">💻<h3>Laptops</h3></div>
<div class="cat">⌚<h3>Watches</h3></div>
<div class="cat">🎧<h3>Audio</h3></div>
<div class="cat">📺<h3>TV</h3></div>
</section>

<section class="products">
<h2 class="title">Featured Products</h2>
<div class="product-grid" id="products"></div>
</section>

<div class="cart" id="cart">
<h2>Shopping Cart</h2>
<hr><br>
<div id="cartItems"></div>
<h3>Total ₹<span id="total">0</span></h3>
<button class="checkout" onclick="checkout()">Checkout</button>
</div>

<button id="topBtn" onclick="window.scrollTo({top:0,behavior:'smooth'})">⬆</button>

<footer>
©️ 2026 TechStore Premium
</footer>

<script>

const items=[
{id:1,name:"Gaming Laptop",price:75000,image:"https://images.unsplash.com/photo-1496181133206-80ce9b88a853?w=800"},
{id:2,name:"Smartphone",price:25000,image:"https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?w=800"},
{id:3,name:"Headphones",price:5000,image:"https://images.unsplash.com/photo-1505740420928-5e560c06d30e?w=800"},
{id:4,name:"Smart Watch",price:8000,image:"https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=800"}
];

let cart=[];

function showProducts(arr){
let box=document.getElementById("products");
box.innerHTML="";
arr.forEach(p=>{
box.innerHTML+=`
<div class="card">
<span class="badge">20% OFF</span>
<button class="wish">❤️</button>
<img src="${p.image}">
<div class="info">
<h3>${p.name}</h3>
<div>⭐⭐⭐⭐⭐</div>
<div class="price">₹${p.price}</div>
<button class="btn" onclick="addCart(${p.id})">Add To Cart</button>
</div>
</div>`;
});
}

showProducts(items);

function addCart(id){
let p=items.find(x=>x.id===id);
cart.push(p);
updateCart();
}

function updateCart(){
let html="";
let total=0;
cart.forEach((x,i)=>{
total+=x.price;
html+=`<p>${x.name} - ₹${x.price}</p><hr>`;
});
document.getElementById("cartItems").innerHTML=html;
document.getElementById("total").innerHTML=total;
document.getElementById("count").innerHTML=cart.length;
}

function toggleCart(){
document.getElementById("cart").classList.toggle("active");
}

function checkout(){
alert("Order Placed Successfully 🎉");
cart=[];
updateCart();
}

function searchProducts(){
let k=document.getElementById("search").value.toLowerCase();
showProducts(items.filter(x=>x.name.toLowerCase().includes(k)));
}

function darkMode(){
document.body.classList.toggle("dark");
}

let slides=document.getElementsByClassName("slide");
let index=0;

function slider(){
for(let i=0;i<slides.length;i++){
slides[i].style.display="none";
}
index++;
if(index>slides.length){index=1;}
slides[index-1].style.display="block";
setTimeout(slider,3000);
}
slider();

</script>

</body>
</html>
