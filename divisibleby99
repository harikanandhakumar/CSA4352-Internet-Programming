<!DOCTYPE html>
<html>
<head>
    <title>Number Greater Than 1000 and Divisible by 99</title>

    <script>
        function findNumber() {
            var num = 1001;

            while (true) {
                if (num % 99 == 0) {
                    document.getElementById("result").innerHTML =
                        "Number = " + num;
                    break;
                }
                num++;
            }
        }
    </script>
</head>
<body>

    <h2>Find a Number Greater Than 1000 and Divisible by 99</h2>

    <button onclick="findNumber()">Find Number</button>

    <p id="result"></p>

</body>
</html>
