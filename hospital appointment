
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MediCare Hospital - Premium Appointment Booking</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

:root{
    --primary:#00b4d8;
    --secondary:#0077b6;
    --dark:#023e8a;
    --light:#f8fafc;
    --success:#16a34a;
}

html{
    scroll-behavior:smooth;
}

body{
    background:linear-gradient(135deg,#f8fafc,#eef6ff);
    color:#333;
}

/* Navbar */

header{
    position:sticky;
    top:0;
    z-index:1000;
    background:rgba(255,255,255,.9);
    backdrop-filter:blur(10px);
    box-shadow:0 2px 15px rgba(0,0,0,.08);
}

nav{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:18px 50px;
}

.logo{
    font-size:28px;
    font-weight:700;
    color:var(--secondary);
}

.nav-right{
    display:flex;
    gap:15px;
    align-items:center;
}

/* Hero */

.hero{
    min-height:80vh;
    display:flex;
    align-items:center;
    justify-content:center;
    flex-direction:column;
    text-align:center;
    color:white;
    background:
    linear-gradient(
    rgba(0,119,182,.85),
    rgba(0,180,216,.85)),
    url("https://images.unsplash.com/photo-1587351021759-3e566b6af7cc?w=1600");
    background-size:cover;
    background-position:center;
}

.hero h1{
    font-size:55px;
    margin-bottom:20px;
    animation:slideDown 1s ease;
}

.hero p{
    font-size:20px;
    max-width:700px;
    animation:fadeIn 1.5s ease;
}

.hero button{
    margin-top:25px;
}

/* General */

.container{
    width:90%;
    max-width:1200px;
    margin:auto;
    padding:60px 0;
}

.section-title{
    text-align:center;
    color:var(--secondary);
    margin-bottom:30px;
    font-size:36px;
}

/* Search */

.search-box{
    margin-bottom:30px;
}

.search-box input{
    width:100%;
    padding:15px;
    border-radius:12px;
    border:none;
    box-shadow:0 4px 10px rgba(0,0,0,.1);
}

/* Cards */

.doctors{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    gap:25px;
}

.card{
    background:white;
    border-radius:20px;
    overflow:hidden;
    box-shadow:0 10px 20px rgba(0,0,0,.08);
    transition:.4s;
}

.card:hover{
    transform:translateY(-10px);
    box-shadow:0 20px 30px rgba(0,180,216,.25);
}

.card img{
    width:100%;
    height:250px;
    object-fit:cover;
    transition:.5s;
}

.card:hover img{
    transform:scale(1.05);
}

.card-content{
    padding:20px;
}

.card-content h3{
    margin-bottom:8px;
}

.rating{
    color:orange;
    margin-top:8px;
}

/* Booking Form */

.booking-form{
    margin-top:60px;
    background:white;
    border-radius:20px;
    padding:35px;
    box-shadow:0 10px 25px rgba(0,0,0,.08);
}

.form-group{
    margin-bottom:18px;
}

label{
    display:block;
    margin-bottom:6px;
    font-weight:600;
}

input,
select,
textarea{
    width:100%;
    padding:13px;
    border:1px solid #ddd;
    border-radius:12px;
    outline:none;
}

input:focus,
select:focus,
textarea:focus{
    border-color:var(--primary);
}

/* Buttons */

button{
    border:none;
    cursor:pointer;
    border-radius:12px;
    padding:12px 22px;
    color:white;
    background:linear-gradient(
    135deg,
    var(--primary),
    var(--secondary));
    transition:.3s;
}

button:hover{
    transform:translateY(-3px);
}

/* Stats */

.stats{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
    gap:20px;
    margin-top:50px;
}

.stat{
    background:white;
    text-align:center;
    padding:30px;
    border-radius:18px;
    box-shadow:0 5px 15px rgba(0,0,0,.08);
}

.stat h2{
    color:var(--secondary);
}

/* Testimonials */

.testimonials{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    gap:20px;
}

.testimonial{
    background:white;
    padding:25px;
    border-radius:18px;
    box-shadow:0 5px 15px rgba(0,0,0,.08);
}

/* Emergency */

.emergency{
    background:#dc2626;
    color:white;
    text-align:center;
    padding:12px;
    font-weight:600;
}

/* Success Popup */

.popup{
    position:fixed;
    top:30px;
    right:-400px;
    background:var(--success);
    color:white;
    padding:15px 25px;
    border-radius:12px;
    transition:.5s;
    z-index:2000;
}

.popup.show{
    right:20px;
}

/* Dark Mode */

.dark-mode{
    background:#121212;
    color:white;
}

.dark-mode .card,
.dark-mode .booking-form,
.dark-mode .stat,
.dark-mode .testimonial{
    background:#1e1e1e;
    color:white;
}

.dark-mode header{
    background:#1a1a1a;
}

/* Footer */

footer{
    background:#111827;
    color:white;
    text-align:center;
    padding:25px;
    margin-top:60px;
}

/* Animations */

@keyframes slideDown{
    from{
        opacity:0;
        transform:translateY(-50px);
    }
    to{
        opacity:1;
        transform:translateY(0);
    }
}

@keyframes fadeIn{
    from{
        opacity:0;
    }
    to{
        opacity:1;
    }
}

/* Mobile */

@media(max-width:768px){

    nav{
        flex-direction:column;
        gap:10px;
        padding:20px;
    }

    .hero h1{
        font-size:36px;
    }

    .hero p{
        font-size:16px;
    }
}
</style>
</head>
<body>

<div class="popup" id="popup">
🎉 Appointment Booked Successfully
</div>

<div class="emergency">
🚑 Emergency Helpline: +91 9876543210
</div>

<header>
<nav>
<div class="logo">🏥 MediCare Hospital</div>

<div class="nav-right">
<button id="darkBtn">🌙 Dark Mode</button>
</div>
</nav>
</header>

<section class="hero">
<h1>Premium Healthcare Services</h1>
<p>
Book appointments with top specialists quickly and securely.
Your health is our priority.
</p>
<button onclick="document.querySelector('.booking-form').scrollIntoView()">
Book Appointment
</button>
</section>

<div class="container">

<h2 class="section-title">Why Choose Us</h2>

<div class="stats">
<div class="stat">
<h2>50+</h2>
<p>Specialist Doctors</p>
</div>

<div class="stat">
<h2>25K+</h2>
<p>Happy Patients</p>
</div>

<div class="stat">
<h2>24/7</h2>
<p>Emergency Care</p>
</div>

<div class="stat">
<h2>15+</h2>
<p>Years Experience</p>
</div>
</div>

<br><br>

<h2 class="section-title">Our Specialists</h2>

<div class="search-box">
<input
type="text"
id="doctorSearch"
placeholder="🔍 Search doctors or specialties...">
</div>

<div class="doctors">

<div class="card">
<img src="https://images.unsplash.com/photo-1559839734-2b71ea197ec2?w=800">
<div class="card-content">
<h3>Dr. Sarah Johnson</h3>
<p>Cardiologist</p>
<p>10+ Years Experience</p>
<div class="rating">⭐⭐⭐⭐⭐ 4.9/5</div>
</div>
</div>

<div class="card">
<img src="https://images.unsplash.com/photo-1612349317150-e413f6a5b16d?w=800">
<div class="card-content">
<h3>Dr. Michael Lee</h3>
<p>Neurologist</p>
<p>12+ Years Experience</p>
<div class="rating">⭐⭐⭐⭐⭐ 4.8/5</div>
</div>
</div>

<div class="card">
<img src="https://images.unsplash.com/photo-1594824476967-48c8b964273f?w=800">
<div class="card-content">
<h3>Dr. Emily Davis</h3>
<p>Pediatrician</p>
<p>8+ Years Experience</p>
<div class="rating">⭐⭐⭐⭐⭐ 4.9/5</div>
</div>
</div>

</div>

<div class="booking-form">

<h2 class="section-title">Book Appointment</h2>

<div class="form-group">
<label>Patient Name</label>
<input type="text" id="name">
</div>

<div class="form-group">
<label>Email</label>
<input type="email" id="email">
</div>

<div class="form-group">
<label>Phone</label>
<input type="tel" id="phone">
</div>

<div class="form-group">
<label>Department</label>
<select id="department">
<option>Cardiology</option>
<option>Neurology</option>
<option>Pediatrics</option>
<option>Orthopedics</option>
<option>Dermatology</option>
</select>
</div>

<div class="form-group">
<label>Doctor</label>
<select id="doctor">
<option>Dr. Sarah Johnson</option>
<option>Dr. Michael Lee</option>
<option>Dr. Emily Davis</option>
</select>
</div>

<div class="form-group">
<label>Date</label>
<input type="date" id="date">
</div>

<div class="form-group">
<label>Time Slot</label>
<select id="time">
<option>09:00 AM</option>
<option>10:00 AM</option>
<option>11:00 AM</option>
<option>02:00 PM</option>
<option>04:00 PM</option>
</select>
</div>

<div class="form-group">
<label>Symptoms / Notes</label>
<textarea rows="4" id="notes"></textarea>
</div>

<button onclick="bookAppointment()">
Confirm Appointment
</button>

<div id="confirmation"></div>

</div>

<br><br>

<h2 class="section-title">Patient Testimonials</h2>

<div class="testimonials">

<div class="testimonial">
⭐⭐⭐⭐⭐
<p>
Excellent doctors and smooth booking process.
</p>
<br>
<b>Rahul Kumar</b>
</div>

<div class="testimonial">
⭐⭐⭐⭐⭐
<p>
Friendly staff and modern facilities.
</p>
<br>
<b>Priya Sharma</b>
</div>

<div class="testimonial">
⭐⭐⭐⭐⭐
<p>
Best hospital experience I've had.
</p>
<br>
<b>Arjun Patel</b>
</div>

</div>

</div>

<footer>
© 2026 MediCare Hospital | All Rights Reserved
</footer>

<script>

/* Dark Mode */

document.getElementById("darkBtn").onclick=function(){
document.body.classList.toggle("dark-mode");
};

/* Search Doctors */

document.getElementById("doctorSearch")
.addEventListener("keyup",function(){

let value=this.value.toLowerCase();

document.querySelectorAll(".card")
.forEach(card=>{

let text=card.innerText.toLowerCase();

card.style.display=
text.includes(value) ? "block" : "none";

});

});

/* Appointment Booking */

function bookAppointment(){

let name=document.getElementById("name").value;
let email=document.getElementById("email").value;
let phone=document.getElementById("phone").value;
let doctor=document.getElementById("doctor").value;
let date=document.getElementById("date").value;
let time=document.getElementById("time").value;

if(
!name ||
!email ||
!phone ||
!date
){
alert("Please fill all required fields");
return;
}

document.getElementById("confirmation").innerHTML=
`
<div style="
margin-top:20px;
padding:20px;
background:#dcfce7;
border-radius:12px;
">
<h3>✅ Appointment Confirmed</h3>
<p><strong>Patient:</strong> ${name}</p>
<p><strong>Doctor:</strong> ${doctor}</p>
<p><strong>Date:</strong> ${date}</p>
<p><strong>Time:</strong> ${time}</p>
</div>
`;

const popup=document.getElementById("popup");

popup.classList.add("show");

setTimeout(()=>{
popup.classList.remove("show");
},3000);

document.querySelector("#confirmation")
.scrollIntoView({
behavior:"smooth"
});
}
</script>

</body>
</html>
