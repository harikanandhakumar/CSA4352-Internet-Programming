<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cocoa Crumbs Bakery</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Segoe UI',sans-serif;
scroll-behavior:smooth;
}

body{
background:linear-gradient(-45deg,#f5ede3,#fff8f0,#e6d5c3,#f5ede3);
background-size:400% 400%;
animation:gradient 12s ease infinite;
}

@keyframes gradient{
0%{background-position:0% 50%;}
50%{background-position:100% 50%;}
100%{background-position:0% 50%;}
}

header{
background:#4e342e;
color:white;
padding:50px;
text-align:center;
animation:slideDown 1s;
}

@keyframes slideDown{
from{
opacity:0;
transform:translateY(-50px);
}
to{
opacity:1;
transform:translateY(0);
}
}

nav{
background:#3e2723;
padding:15px;
text-align:center;
}

nav a{
color:white;
text-decoration:none;
margin:15px;
font-weight:bold;
}

nav a:hover{
color:#ffd54f;
}

.hero{
text-align:center;
padding:80px 20px;
}

.hero h2{
font-size:45px;
color:#4e342e;
animation:float 3s infinite;
}

@keyframes float{
0%{transform:translateY(0);}
50%{transform:translateY(-10px);}
100%{transform:translateY(0);}
}

.hero p{
margin-top:10px;
font-size:18px;
}

.section-title{
text-align:center;
margin:30px;
color:#4e342e;
}

.cakes{
display:flex;
flex-wrap:wrap;
justify-content:center;
gap:25px;
padding:20px;
}

.card{
width:260px;
background:white;
border-radius:15px;
overflow:hidden;
box-shadow:0 5px 15px rgba(0,0,0,.2);
transition:.4s;
}

.card:hover{
transform:translateY(-10px) scale(1.03);
}

.card img{
width:100%;
height:200px;
object-fit:cover;
transition:.5s;
}

.card:hover img{
transform:scale(1.1);
}

.card-content{
padding:15px;
text-align:center;
}

.price{
color:green;
font-size:22px;
margin:10px;
font-weight:bold;
}

button{
background:#6d4c41;
color:white;
border:none;
padding:10px 20px;
border-radius:20px;
cursor:pointer;
transition:.3s;
}

button:hover{
background:#4e342e;
box-shadow:0 0 15px #8d6e63;
}

.form-box{
max-width:700px;
background:white;
margin:50px auto;
padding:25px;
border-radius:15px;
box-shadow:0 5px 15px rgba(0,0,0,.2);
}

.form-box h2{
text-align:center;
margin-bottom:20px;
color:#4e342e;
}

input,textarea{
width:100%;
padding:12px;
margin:10px 0;
border:1px solid #ccc;
border-radius:8px;
}

.submit-btn{
width:100%;
}

footer{
background:#3e2723;
color:white;
text-align:center;
padding:25px;
margin-top:50px;
}

</style>
</head>

<body>

<header>
<h1>🎂 Cocoa Crumbs Bakery</h1>
<p>Luxury Cakes Crafted With Love</p>
</header>

<nav>
<a href="#">Home</a>
<a href="#cakes">Cakes</a>
<a href="#order">Order</a>
<a href="#contact">Contact</a>
</nav>

<section class="hero">
<h2>Freshly Baked Happiness</h2>
<p>Premium Cakes For Every Celebration</p>
</section>

<h2 class="section-title" id="cakes">🍰 Our Cake Collection</h2>

<div class="cakes">

<div class="card">
<img src="https://images.unsplash.com/photo-1578985545062-69928b1d9587">
<div class="card-content">
<h3>Chocolate Truffle</h3>
<div class="price">₹599</div>
<button onclick="selectCake('Chocolate Truffle')">Order Now</button>
</div>
</div>

<div class="card">
<img src="https://images.unsplash.com/photo-1464349095431-e9a21285b5f3">
<div class="card-content">
<h3>Strawberry Cake</h3>
<div class="price">₹699</div>
<button onclick="selectCake('Strawberry Cake')">Order Now</button>
</div>
</div>

<div class="card">
<img src="https://images.unsplash.com/photo-1535141192574-5d4897c12636">
<div class="card-content">
<h3>Vanilla Delight</h3>
<div class="price">₹499</div>
<button onclick="selectCake('Vanilla Delight')">Order Now</button>
</div>
</div>

<div class="card">
<img src="https://images.unsplash.com/photo-1551024601-bec78aea704b">
<div class="card-content">
<h3>Red Velvet</h3>
<div class="price">₹799</div>
<button onclick="selectCake('Red Velvet')">Order Now</button>
</div>
</div>

<div class="card">
<img src="https://images.unsplash.com/photo-1486427944299-d1955d23e34d">
<div class="card-content">
<h3>Black Forest</h3>
<div class="price">₹649</div>
<button onclick="selectCake('Black Forest')">Order Now</button>
</div>
</div>

<div class="card">
<img src="https://images.unsplash.com/photo-1519864600265-abb23847ef2c">
<div class="card-content">
<h3>Wedding Cake</h3>
<div class="price">₹2999</div>
<button onclick="selectCake('Wedding Cake')">Order Now</button>
</div>
</div>

</div>

<div class="form-box" id="order">

<h2>Place Your Order</h2>

<form onsubmit="placeOrder(event)">

<input type="text" placeholder="Full Name" required>

<input type="tel" placeholder="Phone Number" required>

<input type="email" placeholder="Email Address" required>

<input type="text" id="cakeName" placeholder="Selected Cake" readonly>

<input type="number" placeholder="Quantity" required>

<textarea rows="4" placeholder="Delivery Address" required></textarea>

<button class="submit-btn" type="submit">
Confirm Order
</button>

</form>

</div>

<footer id="contact">
<h3>Contact Us</h3>
<p>📞 +91 9876543210</p>
<p>📧 cocoacrumbs@gmail.com</p>
<p>©️ 2026 Cocoa Crumbs Bakery</p>
</footer>

<script>

function selectCake(cake){

document.getElementById("cakeName").value=cake;

document.getElementById("order")
.scrollIntoView({
behavior:"smooth"
});

}

function placeOrder(event){

event.preventDefault();

let cake=
document.getElementById("cakeName").value;

if(cake===""){
alert("Please select a cake first.");
return;
}

alert(
"🎂 ORDER CONFIRMED 🎂\n\n"+
"Cake: "+cake+
"\nStatus: Preparing\n\n"+
"Thank you for ordering from Cocoa Crumbs Bakery ❤️"
);

}

</script>

</body>
</html>
